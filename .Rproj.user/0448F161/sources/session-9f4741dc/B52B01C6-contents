compute_entry_events <- function(ind_prep) {
  
  matrices <- ind_prep |>
    unnest_wider("indicators") |>
    filter(app_year > 2005) |>
    arrange(app_year) |>
    select(app_year, rca_bin)
  
  years <- matrices$app_year
  mats  <- matrices$rca_bin
  
  map2_dfr(
    mats[-length(mats)],
    mats[-1],
    \(prev, curr) {
      
      # build entry matrix using direct matrix indexing
      entry_mat <- matrix(NA_integer_, nrow = nrow(curr), ncol = ncol(curr),
                          dimnames = dimnames(curr))
      
      entry_mat[prev == 0L & curr == 1L] <- 1L  # entered
      entry_mat[prev == 0L & curr == 0L] <- 0L  # did not enter
      # prev == 1L cells stay NA (already specialised)
      
      entry_mat |>
        as.data.frame() |>
        rownames_to_column("region") |>
        pivot_longer(-region, names_to = "industry", values_to = "entry")
    },
    .id = "period"
  ) |>
    mutate(
      period = as.integer(period),
      year   = years[period + 1]
    )
}

compute_exit_events <- function(ind_prep) {
  
  matrices <- ind_prep |>
    unnest_wider("indicators") |>
    filter(app_year > 2005) |>
    arrange(app_year) |>
    select(app_year, rca_bin)
  
  years <- matrices$app_year
  mats  <- matrices$rca_bin
  
  map2_dfr(
    mats[-length(mats)],
    mats[-1],
    \(prev, curr) {
      
      # build exit matrix using direct matrix indexing
      exit_mat <- matrix(NA_integer_, nrow = nrow(curr), ncol = ncol(curr),
                         dimnames = dimnames(curr))
      
      exit_mat[prev == 1L & curr == 0L] <- 1L  # exited
      exit_mat[prev == 1L & curr == 1L] <- 0L  # stayed specialised
      # prev == 0L cells stay NA (not at risk of exiting)
      
      exit_mat |>
        as.data.frame() |>
        rownames_to_column("region") |>
        pivot_longer(-region, names_to = "industry", values_to = "exit")
    },
    .id = "period"
  ) |>
    mutate(
      period = as.integer(period),
      year   = years[period + 1]
    )
}
build_flat_table <- function(ind_prep) {
  ind_prep %>%
    mutate(
      long = pmap(
        list(rca, rca_bin, relatedness_density, rcomp, tcomp),
        \(rca, bin, rel, rcomp, tcomp) {
          
          pivot_mat <- \(mat, nm) {
            mat %>%
              as.data.frame() %>%
              rownames_to_column("region") %>%
              pivot_longer(-region, names_to = "tech", values_to = nm)
          }
          
          # pivot each matrix explicitly with its column name
          pivot_mat(rca, "rca") %>%
            left_join(pivot_mat(bin, "rca_bin"),             by = c("region", "tech")) %>%
            left_join(pivot_mat(rel, "relatedness_density"), by = c("region", "tech")) %>%
            left_join(
              enframe(rcomp, name = "region", value = "region_complexity"),
              by = "region"
            ) %>%
            left_join(
              enframe(tcomp, name = "tech", value = "tech_complexity"),
              by = "tech"
            )
        }
      )
    ) %>%
    select(app_year, long) %>%
    unnest(long)
}
