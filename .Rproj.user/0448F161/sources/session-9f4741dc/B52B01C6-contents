compute_relatedness_measures <- function(data) {
  # Step 1: Create region-industry matrix (patent counts)
  mat <- data %>%
    select(region, industry, value) %>%
    pivot_wider(names_from = industry, values_from = value, values_fill = 0) %>%
    column_to_rownames("region") %>%
    as.matrix()
  
  # Step 2: Compute RCA
  rca_mat <- EconGeo::rca(mat, binary = FALSE)
  rca_bin <- EconGeo::rca(mat, binary = TRUE)
  
  # rca_bin_list <- EconGeo::get
  
  # Step 3: Compute co-occurrence (transpose so industries are rows, regions are columns)
  co_oc <- EconGeo::co_occurrence(t(rca_bin), diagonal = FALSE)
  
  # Step 4: Compute relatedness
  rel <- EconGeo::relatedness(co_oc, method = "prob")
  
  # Step 5: Compute relatedness density
  rel_density <- EconGeo::relatedness_density(rca_bin, rel)
  
  # Step 6: Compute complexity measures with the method of reflection
  # regional complexity
  rcomp <- EconGeo::morc(mat = rca_bin) 
  # technological complexity
  tcomp <- EconGeo::mort(mat = rca_bin)
  
  # Return as list
  list(
    rca = rca_mat,
    rca_bin = rca_bin,
    co_occurrence = co_oc,
    relatedness = rel,
    relatedness_density = rel_density,
    rcomp = rcomp,
    tcomp = tcomp
  )
}


